# Local-only via Ollama — no API key needed, no cost.
# Make sure Ollama is running (`ollama serve`, or it auto-starts on Mac after install)
# and you've pulled the models: `ollama pull nomic-embed-text` and `ollama pull llama3.2`

OLLAMA_HOST=http://localhost:11434

# Defaults shown below — override only if you want different behavior
EMBEDDING_MODEL=nomic-embed-text
CHAT_MODEL=llama3.2
JUDGE_MODEL=llama3.2

CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K_RETRIEVE=10
TOP_K_FINAL=4
USE_RERANKER=true
HYBRID_ALPHA=0.5

GENERATION_TEMPERATURE=0.1

ENABLE_INPUT_GUARDRAILS=true
ENABLE_OUTPUT_GUARDRAILS=true

APP_ENV=development
ALLOWED_ORIGINS=*
CHROMA_DIR=./chroma_db
